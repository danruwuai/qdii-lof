# 集思录 cookie（用于获取申购状态和限额）
# 获取方式：登录 jisilu.cn，从浏览器复制 cookie
JISILI_COOKIE=

# 数据库路径
DATABASE_URL=sqlite:///./data/qdii.db

# 服务端口
PORT=8000
HOST=0.0.0.0

# 刷新间隔（秒）
REFRESH_INTERVAL_CN=5
REFRESH_INTERVAL_HK=10
REFRESH_INTERVAL_US=15
REFRESH_INTERVAL_PREMIUM=10
REFRESH_INTERVAL_STATUS=600
REFRESH_INTERVAL_NAV=1800

# ==================== 微信公众号配置 ====================
# 公众号 AppID（在微信公众平台 -> 开发 -> 基本配置中获取）
WECHAT_APP_ID=

# 公众号 AppSecret（在微信公众平台 -> 开发 -> 基本配置中获取）
WECHAT_APP_SECRET=

# 消息接收 Token（在公众号后台 -> 开发 -> 基本配置中设置）
WECHAT_TOKEN=

# 消息接收 EncodingAESKey（在公众号后台 -> 开发 -> 基本配置中设置）
WECHAT_ENCODING_AES_KEY=

# 模板消息模板ID（在公众号后台 -> 功能 -> 模板消息 -> 模板库中申请并获取）
# 注意：个人订阅号可用模板类别有限，金融类模板可能无法申请
WECHAT_TEMPLATE_ID=

# 订阅通知模板ID（替代方案，需要用户主动订阅）
WECHAT_SUBSCRIBE_TEMPLATE_ID=

# JS安全域名（公众号后台 -> 开发 -> 基本配置中设置，用于OAuth跳转）
# 例如：example.com（不要带http://）
WECHAT_CALLBACK_URL=

# 是否使用客服消息替代模板消息（48小时内有效，不需要模板ID）
WECHAT_USE_CUSTOMER_SERVICE=false

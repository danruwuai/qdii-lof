.fund-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.fund-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.fund-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.fund-code {
  font-size: 22rpx;
  color: #999;
}

.fund-price {
  text-align: right;
}

.price {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.change {
  font-size: 24rpx;
  display: block;
}

.text-green {
  color: #00b578;
}

.text-red {
  color: #ff4d4f;
}

.fund-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.premium {
  font-size: 26rpx;
  font-weight: 600;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background: #f0f0f0;
  color: #666;
}

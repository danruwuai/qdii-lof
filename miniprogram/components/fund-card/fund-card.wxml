<view class="fund-card" bindtap="onTap">
  <view class="fund-header">
    <view class="fund-info">
      <text class="fund-name">{{fund.name}}</text>
      <text class="fund-code">{{fund.code}}</text>
    </view>
    <view class="fund-price">
      <text class="price">{{price}}</text>
      <text class="change {{changeClass}}">{{change}}</text>
    </view>
  </view>
  <view class="fund-footer">
    <text class="premium" style="color: {{premiumColor}}">溢价 {{premium}}</text>
    <text class="tag">{{venue}}</text>
  </view>
</view>

<view class="container" wx:if="{{fund}}">
  <!-- Fund header -->
  <view class="header-card">
    <view class="fund-title">
      <text class="fund-name">{{fund.name}}</text>
      <text class="fund-code">{{fund.code}}</text>
    </view>
    <button class="watchlist-btn {{inWatchlist ? 'active' : ''}}" bindtap="toggleWatchlist">
      {{inWatchlist ? '已监控' : '+ 监控'}}
    </button>
  </view>

  <!-- Price info -->
  <view class="price-card">
    <view class="price-row">
      <text class="price-label">实时价格</text>
      <text class="price-value">{{price}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">涨跌幅</text>
      <text class="price-value {{change_class}}">{{change_pct}}</text>
    </view>
    <view class="divider"></view>
    <view class="price-row">
      <text class="price-label">估算净值</text>
      <text class="price-value">{{est_nav}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">官方净值</text>
      <text class="price-value">{{nav}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">净值日期</text>
      <text class="price-value">{{fund.nav_date || '--'}} ({{fund.nav_accuracy || '--'}})</text>
    </view>
    <view class="divider"></view>
    <view class="price-row premium-row">
      <text class="price-label premium-label">实时溢价率</text>
      <text class="price-large" style="color: {{premium_color}}">{{premium_rate}}</text>
    </view>
    <text class="calc-method">计算方法: Type {{calc_method}}</text>
  </view>

  <!-- Subscription info -->
  <view class="sub-card">
    <view class="sub-title">申购信息</view>
    <view class="sub-row">
      <text class="sub-label">交易场所</text>
      <text class="sub-value">{{fund.trading_venue || '--'}}</text>
    </view>
    <view class="sub-row">
      <text class="sub-label">申购状态</text>
      <text class="sub-value {{fund.can_subscribe ? 'text-green' : 'text-red'}}">{{fund.subscribe_status}}</text>
    </view>
    <view class="sub-row">
      <text class="sub-label">日内限额</text>
      <text class="sub-value">{{daily_limit_text}}</text>
    </view>
    <view class="sub-row">
      <text class="sub-label">场内买入</text>
      <text class="sub-value {{fund.can_buy ? 'text-green' : 'text-red'}}">{{fund.can_buy ? '允许' : '禁止'}}</text>
    </view>
    <view class="sub-row">
      <text class="sub-label">场内卖出</text>
      <text class="sub-value {{fund.can_sell ? 'text-green' : 'text-red'}}">{{fund.can_sell ? '允许' : '禁止'}}</text>
    </view>
  </view>

  <!-- Holdings -->
  <view class="holding-card" wx:if="{{holdings.length > 0}}">
    <view class="sub-title">前十大持仓</view>
    <view class="holding-item" wx:for="{{holdings}}" wx:key="asset_code">
      <view class="holding-info">
        <text class="holding-name">{{item.asset_name}}</text>
        <text class="holding-code">{{item.asset_code}}</text>
      </view>
      <text class="holding-weight">{{item.weight}}%</text>
    </view>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">加载中...</view>

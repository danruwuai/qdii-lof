<view class="container">
  <!-- Search bar -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索基金代码或名称" value="{{searchValue}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" />
  </view>

  <!-- Tab bar -->
  <scroll-view class="tab-bar" scroll-x="true" scroll-with-animation>
    <view class="tab-item {{activeTab === item.key ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="key" data-tab="{{item.key}}" bindtap="onTabChange">
      <text class="tab-label">{{item.label}}</text>
      <text class="tab-badge" wx:if="{{item.count > 0}}">{{item.count}}</text>
    </view>
  </scroll-view>

  <!-- Sort buttons -->
  <view class="filter-bar">
    <view class="sort-buttons">
      <view class="sort-btn {{sortField === 'premium_rate' ? 'active' : ''}}" data-field="premium_rate" bindtap="onSortChange">
        <text>溢价率</text>
        <text class="sort-dir" wx:if="{{sortField === 'premium_rate'}}">{{sortDirection === 'asc' ? '↑' : '↓'}}</text>
      </view>
      <view class="sort-btn {{sortField === 'change_pct' ? 'active' : ''}}" data-field="change_pct" bindtap="onSortChange">
        <text>涨跌幅</text>
        <text class="sort-dir" wx:if="{{sortField === 'change_pct'}}">{{sortDirection === 'asc' ? '↑' : '↓'}}</text>
      </view>
      <view class="sort-btn {{sortField === 'market_price' ? 'active' : ''}}" data-field="market_price" bindtap="onSortChange">
        <text>价格</text>
        <text class="sort-dir" wx:if="{{sortField === 'market_price'}}">{{sortDirection === 'asc' ? '↑' : '↓'}}</text>
      </view>
      <view class="sort-btn {{sortField === 'estimated_nav' ? 'active' : ''}}" data-field="estimated_nav" bindtap="onSortChange">
        <text>估算净值</text>
        <text class="sort-dir" wx:if="{{sortField === 'estimated_nav'}}">{{sortDirection === 'asc' ? '↑' : '↓'}}</text>
      </view>
      <view class="sort-btn {{sortField === 'volume' ? 'active' : ''}}" data-field="volume" bindtap="onSortChange">
        <text>成交量</text>
        <text class="sort-dir" wx:if="{{sortField === 'volume'}}">{{sortDirection === 'asc' ? '↑' : '↓'}}</text>
      </view>
      <view class="sort-btn {{sortField === 'daily_limit' ? 'active' : ''}}" data-field="daily_limit" bindtap="onSortChange">
        <text>申购限额</text>
        <text class="sort-dir" wx:if="{{sortField === 'daily_limit'}}">{{sortDirection === 'asc' ? '↑' : '↓'}}</text>
      </view>
    </view>
  </view>

  <!-- Filter bar -->
  <view class="filter-bar filter-bar-secondary">
    <view class="filter-buttons">
      <!-- 申购状态筛选 -->
      <view class="filter-dropdown">
        <view class="filter-btn {{filterCanSubscribe !== null ? 'active' : ''}}" bindtap="onFilterCanSubscribeChange" data-value="true">
          <text>申购状态</text>
          <text class="filter-dir" wx:if="{{filterCanSubscribe === true}}">可申购</text>
          <text class="filter-dir" wx:elif="{{filterCanSubscribe === false}}">暂停</text>
        </view>
      </view>
      <!-- 溢价等级筛选 -->
      <view class="filter-dropdown">
        <view class="filter-btn {{filterPremiumLevel ? 'active' : ''}}" bindtap="onFilterPremiumLevelChange" data-value="high">
          <text>溢价等级</text>
          <text class="filter-dir" wx:if="{{filterPremiumLevel === 'high'}}">高</text>
          <text class="filter-dir" wx:elif="{{filterPremiumLevel === 'normal'}}">正常</text>
          <text class="filter-dir" wx:elif="{{filterPremiumLevel === 'discount'}}">折价</text>
        </view>
      </view>
      <!-- 套利类型筛选 -->
      <view class="filter-dropdown">
        <view class="filter-btn {{filterArbitrageType ? 'active' : ''}}" bindtap="onFilterArbitrageTypeChange">
          <text>套利类型</text>
          <text class="filter-dir" wx:if="{{filterArbitrageType}}">{{filterArbitrageType}}</text>
        </view>
        <!-- 套利类型下拉选项 -->
        <view class="filter-options" wx:if="{{showArbitrageOptions}}">
          <view class="filter-option {{filterArbitrageType === '溢价套利' ? 'active' : ''}}" data-value="溢价套利" bindtap="onFilterArbitrageTypeSelect">溢价套利</view>
          <view class="filter-option {{filterArbitrageType === '持有者卖出' ? 'active' : ''}}" data-value="持有者卖出" bindtap="onFilterArbitrageTypeSelect">持有者卖出</view>
          <view class="filter-option {{filterArbitrageType === '折价埋伏' ? 'active' : ''}}" data-value="折价埋伏" bindtap="onFilterArbitrageTypeSelect">折价埋伏</view>
          <view class="filter-option {{filterArbitrageType === '低溢价埋伏' ? 'active' : ''}}" data-value="低溢价埋伏" bindtap="onFilterArbitrageTypeSelect">低溢价埋伏</view>
          <view class="filter-option {{filterArbitrageType === '溢价回落' ? 'active' : ''}}" data-value="溢价回落" bindtap="onFilterArbitrageTypeSelect">溢价回落</view>
        </view>
      </view>
      <!-- 跟踪地区筛选 -->
      <view class="filter-dropdown">
        <view class="filter-btn {{filterRegion ? 'active' : ''}}" bindtap="onFilterRegionChange" data-value="US">
          <text>地区</text>
          <text class="filter-dir" wx:if="{{filterRegion}}">{{filterRegion}}</text>
        </view>
      </view>
      <!-- 清除筛选按钮 -->
      <view class="filter-btn clear-btn" bindtap="clearFilters" wx:if="{{activeFilters.length > 0}}">
        <text>清除</text>
      </view>
    </view>
  </view>

  <!-- Active filters -->
  <view class="active-filters" wx:if="{{activeFilters.length > 0}}">
    <view class="active-filter-tag" wx:for="{{activeFilters}}" wx:key="type">
      <text>{{item.label}}</text>
      <text class="remove-tag" bindtap="onFilter{{item.type}}Change">✕</text>
    </view>
    <text class="clear-all" bindtap="clearFilters">全部清除</text>
  </view>

  <!-- Status bar -->
  <view class="status-bar">
    <text class="update-time">更新于 {{lastUpdateTime}}</text>
    <text class="total-count">已加载 {{funds.length}} / {{total}} 只</text>
  </view>

  <!-- Fund list -->
  <view class="fund-list" wx:if="{{!loading}}">
    <view class="fund-card" wx:for="{{funds}}" wx:key="code" data-code="{{item.code}}" bindtap="onDetailTap">
      <view class="fund-header">
        <view class="fund-info">
          <text class="fund-name">{{item.name}}</text>
          <text class="fund-code">{{item.code}}</text>
        </view>
        <view class="fund-tags">
          <text class="tag tag-type">{{item.fund_type}}</text>
          <text class="tag {{item.can_subscribe ? 'tag-open' : 'tag-closed'}}">{{item.subscribe_status}}</text>
          <text class="tag tag-high-premium" wx:if="{{item.is_high_premium}}">极高溢价</text>
          <text class="tag tag-arbitrage" wx:if="{{item.arbitrage_type}}">{{item.arbitrage_type}}</text>
        </view>
        <!-- Star button -->
        <view class="star-btn" data-code="{{item.code}}" catchtap="toggleWatchlist">
          <text class="{{item.is_watched ? 'star-filled' : 'star-empty'}}">★</text>
        </view>
      </view>

      <view class="fund-data">
        <view class="data-item">
          <text class="data-label">价格</text>
          <text class="data-value">{{item.market_price}}</text>
        </view>
        <view class="data-item">
          <text class="data-label">涨跌幅</text>
          <text class="data-value {{item.change_class}}">{{item.change_pct}}</text>
        </view>
        <view class="data-item">
          <text class="data-label">溢价率</text>
          <text class="data-value" style="color: {{item.premium_color}}">{{item.premium_rate}}</text>
        </view>
        <view class="data-item">
          <text class="data-label">估算净值</text>
          <text class="data-value">{{item.estimated_nav}}</text>
        </view>
        <view class="data-item">
          <text class="data-label">方法</text>
          <text class="data-value">Type {{item.calc_method}} ({{item.nav_accuracy}})</text>
        </view>
      </view>

      <!-- Subscription info -->
      <view class="sub-info">
        <text class="sub-value {{item.can_subscribe ? 'text-green' : 'text-red'}}">{{item.subscribe_status}}</text>
        <text class="sub-divider"> | </text>
        <text class="sub-value">{{item.daily_limit_text}}</text>
        <text class="sub-divider"> | </text>
        <text class="sub-value sub-settlement">{{item.settlement_text}}</text>
      </view>

      <!-- Arbitrage profit -->
      <view class="sub-info arbitrage-info" wx:if="{{item.arbitrage_type && item.net_profit_text}}">
        <text class="sub-label">套利净收益: </text>
        <text class="sub-value text-orange">{{item.net_profit_text}}</text>
        <text class="sub-label sub-hint">（已扣申购费0.15%+佣金0.03%）</text>
      </view>
      <view class="sub-info arbitrage-info" wx:elif="{{activeTab === 'arbitrage' && item.estimated_daily_profit_text}}">
        <text class="sub-label">预估日收益: </text>
        <text class="sub-value text-orange">{{item.estimated_daily_profit_text}}</text>
      </view>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- Load more status -->
  <view class="load-more" wx:if="{{!loading && funds.length > 0}}">
    <text wx:if="{{loadingMore}}">加载更多...</text>
    <text wx:elif="{{!hasMore}}">已加载全部 {{total}} 只</text>
    <text wx:else>上拉加载更多</text>
  </view>

  <!-- Empty state -->
  <view class="empty-state" wx:if="{{!loading && funds.length === 0}}">
    <text wx:if="{{activeTab === 'watchlist'}}">暂无关注基金</text>
    <text wx:elif="{{activeTab === 'arbitrage'}}">暂无套利机会</text>
    <text wx:else>暂无数据</text>
  </view>
</view>

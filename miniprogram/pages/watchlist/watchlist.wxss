.container {
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.count {
  font-size: 24rpx;
  color: #999;
}

.fund-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fund-main {
  flex: 1;
}

.fund-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
}

.fund-code {
  font-size: 22rpx;
  color: #999;
}

.fund-price {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.premium {
  font-size: 24rpx;
  font-weight: 500;
}

.remove-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #fff1f0;
  color: #ff4d4f;
  border: none;
  line-height: 1.4;
}

.empty {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

<view class="container">
  <view class="section">
    <view class="section-title">服务器设置</view>
    <view class="setting-row">
      <text class="setting-label">API 地址</text>
      <input class="setting-input" value="{{baseUrl}}" bindinput="onBaseUrlChange" />
    </view>
  </view>

  <view class="section">
    <view class="section-title">市场状态</view>
    <view class="status-row" wx:if="{{marketStatus}}">
      <view class="status-item">
        <text class="status-name">A股</text>
        <text class="status-dot {{marketStatus.cn === 'open' ? 'green' : 'gray'}}"></text>
      </view>
      <view class="status-item">
        <text class="status-name">港股</text>
        <text class="status-dot {{marketStatus.hk === 'open' ? 'green' : 'gray'}}"></text>
      </view>
      <view class="status-item">
        <text class="status-name">美股</text>
        <text class="status-dot {{marketStatus.us === 'open' ? 'green' : 'gray'}}"></text>
      </view>
      <view class="status-item">
        <text class="status-name">日股</text>
        <text class="status-dot {{marketStatus.jp === 'open' ? 'green' : 'gray'}}"></text>
      </view>
      <view class="status-item">
        <text class="status-name">欧股</text>
        <text class="status-dot {{marketStatus.eu === 'open' ? 'green' : 'gray'}}"></text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">关于</view>
    <view class="about-row">
      <text class="about-label">版本</text>
      <text class="about-value">v0.1.0</text>
    </view>
    <view class="about-row">
      <text class="about-label">说明</text>
      <text class="about-value">QDII/LOF/ETF 实时溢价率监控工具</text>
    </view>
  </view>
</view>
